# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Root temporary files
.cache/
coverage/
tmp/
temp/

# Backend / Composer
/vendor/
backend/vendor/
backend/.phpunit.cache/
backend/.phpunit.result.cache
backend/composer.lock
/composer.lock

# Frontend / Node
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.turbo/
frontend/.vite/
frontend/coverage/
frontend/*.tsbuildinfo

# Frontend Playwright artifacts (never committed)
frontend/playwright-report/
frontend/test-results/
frontend/blob-report/
