{
    "name": "humdek/sh2-shp-survey-js",
    "description": "SelfHelp CMS plugin: SurveyJS v2 backend (Symfony bundle).",
    "type": "symfony-bundle",
    "license": "MPL-2.0",
    "version": "0.2.11",
    "require": {
        "php": ">=8.4",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/orm": "^3.6.3",
        "symfony/framework-bundle": "7.4.*",
        "symfony/event-dispatcher": "7.4.*",
        "symfony/http-foundation": "7.4.*",
        "symfony/dependency-injection": "7.4.*",
        "symfony/config": "7.4.*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Humdek\\SurveyJsBundle\\": "backend/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Humdek\\SurveyJsBundle\\Tests\\": "backend/tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
