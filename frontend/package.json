{
    "name": "@humdek/sh2-shp-survey-js",
    "version": "0.1.0",
    "description": "SurveyJS v2 frontend integration for the SelfHelp CMS plugin ecosystem.",
    "license": "MPL-2.0",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external react-dom --external @mantine/core --external @selfhelp/shared",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external react-dom --external @mantine/core --external @selfhelp/shared",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "@mantine/core": "^9.0.0",
        "@selfhelp/shared": "^1.0.4",
        "survey-core": "^2",
        "survey-creator-react": "^2",
        "survey-react-ui": "^2"
    },
    "devDependencies": {
        "@mantine/core": "^9.0.2",
        "@selfhelp/shared": "^1.0.4",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "survey-core": "^2",
        "survey-creator-react": "^2",
        "survey-react-ui": "^2",
        "tsup": "^8.3.5",
        "typescript": "^5.9.3"
    },
    "sideEffects": false
}
