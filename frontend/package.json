{
    "name": "@humdek/sh2-shp-survey-js",
    "version": "1.0.0",
    "description": "SurveyJS v2 frontend integration for the SelfHelp CMS plugin ecosystem.",
    "license": "MPL-2.0",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external react-dom --external @mantine/core --external @selfhelp/shared",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external react-dom --external @mantine/core --external @selfhelp/shared",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": "^19",
        "react-dom": "^19",
        "@mantine/core": "^7",
        "@selfhelp/shared": "^1.0.3",
        "survey-core": "^2",
        "survey-creator-react": "^2",
        "survey-react-ui": "^2"
    },
    "dependencies": {
        "@tiptap/core": "^2.6.6",
        "@tiptap/extension-link": "^2.6.6",
        "@tiptap/pm": "^2.6.6",
        "@tiptap/react": "^2.6.6",
        "@tiptap/starter-kit": "^2.6.6"
    },
    "devDependencies": {
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "tsup": "^8.3.5",
        "typescript": "^5.6.0"
    },
    "sideEffects": false
}
