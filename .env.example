#
# Copy this file to `.env` (gitignored) and fill in the values you need.
# `scripts/build-shplugin.mjs`, `scripts/install-local.mjs` and
# `scripts/publish-to-registry.mjs` all auto-load this file via Node's
# native `process.loadEnvFile` (Node >= 20.12 / 22+) before reading
# `process.env`. Real process-env values still win, so CI secrets
# injected into a workflow run override `.env` automatically.
#
# NEVER commit `.env`. The repo's `.gitignore` already excludes it.

# ---------------------------------------------------------------------
# Local development signing key (keyId="dev")
# ---------------------------------------------------------------------
# Base64 of the 64-byte Ed25519 secret key produced by
# `node ../sh2-plugin-registry/scripts/sign.mjs keygen`.
#
# When set (and SELFHELP_PLUGIN_SIGNING_KEY is NOT set), the build
# script signs the canonical payload with this key and stamps
# `keyId="dev"`. The host accepts dev-signed archives only when:
#   - APP_ENV=dev on the host, AND
#   - SELFHELP_PLUGIN_TRUSTED_KEYS contains a matching `dev=<base64-pubkey>`
#     entry on the host (paste the public half of the keypair).
#
# Production hosts (APP_ENV=prod or test) reject keyId="dev" outright on
# `official` / `reviewed` plugins regardless of trusted-keys.
#SELFHELP_PLUGIN_DEV_SIGNING_KEY=

# ---------------------------------------------------------------------
# Production / CI signing key
# ---------------------------------------------------------------------
# Base64 of the production Ed25519 secret key. Use only on a CI runner
# (GitHub Actions secrets, etc.). When set, the build script signs the
# canonical payload with this key and stamps the matching key id below.
#SELFHELP_PLUGIN_SIGNING_KEY=

# Publisher key id, must match an entry in the host's
# SELFHELP_PLUGIN_TRUSTED_KEYS env (e.g. `humdek-prod-2026`).
#SELFHELP_PLUGIN_SIGNING_KEY_ID=

# ---------------------------------------------------------------------
# install-local.mjs - local host install
# ---------------------------------------------------------------------
# Admin JWT bearer token for the local host's
# /cms-api/v1/admin/plugins/install endpoint. install-local.mjs reads
# it from --token <jwt> first, then this env, then errors out.
#SELFHELP_ADMIN_TOKEN=

# Base URL of the local host (default http://localhost:8000).
#SELFHELP_API_BASE=http://localhost:8000

# Absolute path to the sh-selfhelp_backend checkout (default
# ../../sh-selfhelp_backend relative to the plugin checkout).
#SELFHELP_BACKEND_PATH=

# ---------------------------------------------------------------------
# publish-to-registry.mjs - registry publisher
# ---------------------------------------------------------------------
# Absolute path to the sh2-plugin-registry checkout (default
# ../sh2-plugin-registry relative to the plugin checkout).
#SELFHELP_REGISTRY_PATH=
