{
    "id": "sh2-shp-survey-js",
    "name": "SurveyJS",
    "description": "SurveyJS v2 integration for SelfHelp CMS. Provides a Mantine-themed Survey Creator (admin), a survey runtime style, and a public submission pipeline that writes into the existing data_tables / data_rows / data_cells. Includes optional GPX, Video, and rich-text custom question types.",
    "version": "0.2.2",
    "pluginApiVersion": "1.1",
    "author": {
        "name": "Humdek, University of Bern",
        "email": "selfhelp@unibe.ch",
        "url": "https://github.com/humdek-unibe-ch"
    },
    "license": "MPL-2.0",
    "homepage": "https://github.com/humdek-unibe-ch/sh2-shp-survey-js",
    "compatibility": {
        "selfhelp": ">=8.0.0-dev <9.0.0",
        "php": "^8.4",
        "node": "^22",
        "react": "^19",
        "reactNative": "^0.83",
        "expoSdk": "^55"
    },
    "dependencies": [],
    "conflicts": [
        {
            "pluginId": "sh-shp-survey_js",
            "version": "*",
            "reason": "Replaced by SurveyJS v2 (sh2-shp-survey-js)."
        }
    ],
    "backend": {
        "bundleClass": "Humdek\\SurveyJsBundle\\HumdekSurveyJsBundle",
        "migrationsNamespace": "Humdek\\SurveyJsBundle\\Migrations",
        "composer": {
            "package": "humdek/sh2-shp-survey-js",
            "version": "0.2.2"
        }
    },
    "frontend": {
        "runtime": {
            "entrypoint": "dist/plugin.esm.js",
            "stylesheet": "dist/plugin.css",
            "format": "esm",
            "devEntrypointUrl": "http://localhost:5174/sh2-shp-survey-js/plugin.esm.js"
        }
    },
    "mobile": {
        "package": "@humdek/sh2-shp-survey-js-mobile",
        "version": "0.2.2",
        "readonly": true
    },
    "security": {
        "trustLevel": "official",
        "capabilities": [
            "backendBundle",
            "databaseMigrations",
            "readDataTables",
            "writeDataTables",
            "lookupOwnGroup",
            "frontendStyles",
            "mobileStyles",
            "adminPages",
            "realtimePublish",
            "secretAccess"
        ],
        "cspRules": {
            "img-src": [
                "https://*.tile.openstreetmap.org",
                "https://*.basemaps.cartocdn.com"
            ]
        },
        "externalHosts": [
            {
                "host": "*.tile.openstreetmap.org",
                "type": "image",
                "reason": "Leaflet tile layers used by the GPX question type preview."
            },
            {
                "host": "*.basemaps.cartocdn.com",
                "type": "image",
                "reason": "Fallback basemap tiles for the GPX preview."
            }
        ],
        "signing": {
            "required": false
        }
    },
    "permissions": [
        {
            "key": "surveyjs.surveys.manage",
            "description": "Create, edit, publish, delete surveys.",
            "defaultRoles": [
                "admin"
            ]
        },
        {
            "key": "surveyjs.surveys.view-responses",
            "description": "View survey responses + dashboard.",
            "defaultRoles": [
                "admin"
            ]
        },
        {
            "key": "surveyjs.surveys.export-pdf",
            "description": "Export survey responses as PDF.",
            "defaultRoles": [
                "admin"
            ]
        },
        {
            "key": "surveyjs.surveys.delete-responses",
            "description": "Delete individual survey responses.",
            "defaultRoles": [
                "admin"
            ]
        },
        {
            "key": "surveyjs.surveys.export-csv",
            "description": "Export survey responses as CSV.",
            "defaultRoles": [
                "admin"
            ]
        },
        {
            "key": "surveyjs.surveys.export-xlsx",
            "description": "Export survey responses as Excel (XLSX).",
            "defaultRoles": [
                "admin"
            ]
        },
        {
            "key": "surveyjs.surveys.export-json",
            "description": "Export survey responses as JSON.",
            "defaultRoles": [
                "admin"
            ]
        },
        {
            "key": "surveyjs.surveys.upload-files",
            "description": "Upload files attached to public survey submissions (file/GPX/microphone questions).",
            "defaultRoles": [
                "admin"
            ]
        }
    ],
    "dataAccess": {
        "ownedTables": [
            "survey_answer_links",
            "survey_files",
            "survey_response_drafts",
            "survey_runs",
            "survey_versions",
            "surveys"
        ],
        "ownedDataTablePrefix": "sh2_surveyjs_",
        "read": [
            "data_tables",
            "data_rows",
            "data_cols",
            "data_cells",
            "lookups",
            "languages"
        ],
        "write": [
            "data_tables",
            "data_rows",
            "data_cols",
            "data_cells"
        ]
    },
    "realtimeTopics": [
        {
            "key": "surveys/{surveyId}/responses",
            "description": "Realtime stream of new survey responses. New entries arrive without polling.",
            "requiredPermission": "surveyjs.surveys.view-responses"
        },
        {
            "key": "surveys/{surveyId}/editing",
            "description": "Collaborative-edit presence + save notifications for the Survey Creator.",
            "requiredPermission": "surveyjs.surveys.manage"
        }
    ],
    "featureFlags": [
        {
            "key": "gpx",
            "description": "Enable GPX track question type.",
            "defaultEnabled": false
        },
        {
            "key": "video",
            "description": "Enable video question type.",
            "defaultEnabled": false
        },
        {
            "key": "microphone",
            "description": "Enable microphone (audio recording) question type.",
            "defaultEnabled": false
        },
        {
            "key": "rich-text",
            "description": "Enable Tiptap-based rich-text question + Creator property editors.",
            "defaultEnabled": true
        },
        {
            "key": "pdf-export",
            "description": "Enable PDF export of survey responses.",
            "defaultEnabled": false
        },
        {
            "key": "dashboard",
            "description": "Enable response dashboard view.",
            "defaultEnabled": true
        },
        {
            "key": "collab-editing",
            "description": "Enable collaborative-edit Mercure notifications in the Creator.",
            "defaultEnabled": true
        }
    ],
    "lookups": {
        "extends": [
            {
                "typeCode": "surveyJsTheme",
                "ownership": "plugin_owned",
                "entries": [
                    {
                        "code": "default",
                        "value": "Default",
                        "description": "Mantine-bridged default theme."
                    },
                    {
                        "code": "modern",
                        "value": "Modern"
                    },
                    {
                        "code": "high-contrast",
                        "value": "High contrast"
                    }
                ]
            }
        ]
    },
    "styles": [
        {
            "name": "surveyjs",
            "description": "Embeds a published SurveyJS survey at runtime. Grouped under the 'Plugin: SurveyJS' style_groups row created by the plugin's migration.",
            "canHaveChildren": false,
            "capability": "frontendStyles"
        },
        {
            "name": "gpxMap",
            "description": "Standalone Leaflet-based map renderer for a GPX answer field. Grouped under the 'Plugin: SurveyJS' style_groups row created by the plugin's migration.",
            "canHaveChildren": false,
            "capability": "frontendStyles"
        }
    ],
    "adminPages": [
        {
            "slug": "surveys",
            "label": "SurveyJS",
            "permission": "surveyjs.surveys.manage",
            "icon": "tabler-clipboard-list"
        }
    ],
    "apiRoutes": [
        {
            "name": "surveyjs_admin_list",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_create",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys",
            "methods": [
                "POST"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_get",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_update",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}",
            "methods": [
                "PUT"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_delete",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}",
            "methods": [
                "DELETE"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_draft_save",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/draft",
            "methods": [
                "PUT"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_versions_create",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/versions",
            "methods": [
                "POST"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_versions_list",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/versions",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_versions_restore",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/versions/{versionId}/restore",
            "methods": [
                "POST"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_presence",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/presence",
            "methods": [
                "POST"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_dashboard",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/dashboard",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.view-responses"
        },
        {
            "name": "surveyjs_admin_responses",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/responses",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.view-responses"
        },
        {
            "name": "surveyjs_admin_response_detail",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/responses/{rid}",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.view-responses"
        },
        {
            "name": "surveyjs_admin_response_pdf",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/responses/{rid}/pdf",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.export-pdf"
        },
        {
            "name": "surveyjs_admin_response_delete",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/responses/{rid}",
            "methods": [
                "DELETE"
            ],
            "permission": "surveyjs.surveys.delete-responses"
        },
        {
            "name": "surveyjs_admin_responses_export",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/responses/export",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.view-responses"
        },
        {
            "name": "surveyjs_admin_dashboard_results",
            "path": "/admin/plugins/sh2-shp-survey-js/surveys/{id}/dashboard/results",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.view-responses"
        },
        {
            "name": "surveyjs_admin_license_key",
            "path": "/admin/plugins/sh2-shp-survey-js/license-key",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_admin_health",
            "path": "/admin/plugins/sh2-shp-survey-js/health",
            "methods": [
                "GET"
            ],
            "permission": "surveyjs.surveys.manage"
        },
        {
            "name": "surveyjs_public_published",
            "path": "/plugins/sh2-shp-survey-js/published/{key}",
            "methods": [
                "GET"
            ]
        },
        {
            "name": "surveyjs_public_submit",
            "path": "/plugins/sh2-shp-survey-js/published/{key}/submit",
            "methods": [
                "POST"
            ]
        },
        {
            "name": "surveyjs_public_progress_get",
            "path": "/plugins/sh2-shp-survey-js/published/{key}/progress",
            "methods": [
                "GET"
            ]
        },
        {
            "name": "surveyjs_public_progress_put",
            "path": "/plugins/sh2-shp-survey-js/published/{key}/progress",
            "methods": [
                "PUT"
            ]
        },
        {
            "name": "surveyjs_public_progress_delete",
            "path": "/plugins/sh2-shp-survey-js/published/{key}/progress",
            "methods": [
                "DELETE"
            ]
        },
        {
            "name": "surveyjs_public_edit",
            "path": "/plugins/sh2-shp-survey-js/published/{key}/edit",
            "methods": [
                "GET"
            ]
        },
        {
            "name": "surveyjs_public_upload",
            "path": "/plugins/sh2-shp-survey-js/published/{key}/files",
            "methods": [
                "POST"
            ]
        },
        {
            "name": "surveyjs_public_file_delete",
            "path": "/plugins/sh2-shp-survey-js/published/{key}/files/{fileId}",
            "methods": [
                "DELETE"
            ]
        },
        {
            "name": "surveyjs_public_file_download",
            "path": "/plugins/sh2-shp-survey-js/files/{fileId}",
            "methods": [
                "GET"
            ]
        },
        {
            "name": "surveyjs_public_choices",
            "path": "/plugins/sh2-shp-survey-js/published/{key}/choices/{token}",
            "methods": [
                "GET"
            ]
        }
    ],
    "scheduledJobs": [],
    "assets": [],
    "health": {
        "endpoint": "/admin/plugins/sh2-shp-survey-js/health",
        "serviceId": "humdek.surveyjs.health_check"
    },
    "labels": {
        "category": "forms",
        "namespace": "surveyjs"
    },
    "archive": {
        "mode": "standalone"
    }
}
