{
    "name": "@humdek/sh2-shp-survey-js-mobile",
    "version": "1.0.0",
    "description": "SurveyJS v2 readonly mobile renderer for the SelfHelp plugin ecosystem.",
    "license": "MPL-2.0",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external react-native --external expo-router --external @selfhelp/shared",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": "^19",
        "react-native": "^0.83",
        "expo-router": "^55",
        "@selfhelp/shared": "^1.0.3"
    },
    "devDependencies": {
        "@types/react": "^19",
        "tsup": "^8.3.5",
        "typescript": "^5.6.0"
    },
    "sideEffects": false
}
