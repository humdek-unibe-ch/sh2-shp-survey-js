parameters:
    level: 6
    paths:
        - src
    excludePaths:
        - src/Migrations/*
    # Stub the host's `App\Plugin\Event\*` classes so PHPStan can
    # resolve their public surface without checking out the host
    # repository. The runtime classes live in
    # `humdek-unibe-ch/sh-selfhelp_backend/src/Plugin/Event/`; the
    # stubs below mirror only the public methods the plugin calls.
    bootstrapFiles:
        - stubs/host-events.php
    ignoreErrors:
        - identifier: missingType.iterableValue
        # Doctrine writes `$id` via reflection on persist; PHPStan only
        # sees the type declaration `?int` and never finds an assign.
        # Keep the nullable so generated proxies stay valid, but tell
        # PHPStan to skip the "unused null type" check for entity IDs.
        -
            identifier: property.unusedType
            path: src/Entity/*.php
        # Host package not installed during plugin-only CI runs. The
        # CoreDataTableWriter targets the host's data-table entity which
        # only exists once the plugin is mounted inside the SelfHelp
        # backend; treating these as warnings would block CI for no
        # signal gain.
        -
            messages:
                - '#App\\Entity\\DataTable#'
                - '#App\\Entity\\Plugin\\Plugin#'
            path: src/Service/CoreDataTableWriter.php
        # Optional XLSX / PDF dependencies: rendered as soft requires
        # so operators can opt into them without forcing every plugin
        # install to pull the bundle in.
        -
            messages:
                - '#PhpOffice\\PhpSpreadsheet#'
            path: src/Service/SurveyExportService.php
        -
            messages:
                - '#Dompdf\\Dompdf#'
            path: src/Service/SurveyPdfService.php
    treatPhpDocTypesAsCertain: false
