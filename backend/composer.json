{
    "name": "humdek/sh2-shp-survey-js",
    "description": "SelfHelp CMS plugin: SurveyJS v2 backend (Symfony bundle).",
    "type": "symfony-bundle",
    "license": "MPL-2.0",
    "require": {
        "php": "^8.4",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/orm": "^3.3",
        "symfony/framework-bundle": "^7.4",
        "symfony/event-dispatcher": "^7.4",
        "symfony/http-foundation": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "symfony/config": "^7.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Humdek\\SurveyJsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Humdek\\SurveyJsBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "phpstan": "phpstan analyse --no-progress",
        "test": "phpunit --testdox || true"
    }
}
